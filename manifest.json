{
  "name": "Remove URL Trackers",
  "description": "Removes tracking parameters from shared links to restore them to their original clean state",
  "version": "1.0.0",
  "manifest_version": 3,
  "minimum_chrome_version": "111",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "all_frames": true,
      "run_at": "document_start",
      "js": [
        "contentscript.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_title": "Remove URL Trackers"
  }
}